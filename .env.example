# ==========================================
# SpaceTrackOps Environment Variables
# ==========================================

# ── BACKEND ──

# Required: OpenRouter API key for AI analysis
# Get one at: https://openrouter.ai/keys
OPENROUTER_API_KEY=your_openrouter_api_key_here
OPENROUTER_MODEL=tencent/hy3-preview:free
OPENROUTER_URL=https://openrouter.ai/api/v1/chat/completions
AI_CACHE_TTL=300

# Optional: CORS origins (comma-separated, default: * allows all)
# CORS_ORIGINS=http://localhost:3000,https://yourdomain.com

# Optional: Log level (default: INFO)
# LOG_LEVEL=INFO

# ── FRONTEND ──

# API URL for the frontend to communicate with the backend
NEXT_PUBLIC_API_URL=http://127.0.0.1:8000
